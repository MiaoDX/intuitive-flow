# Plan bakeoff provider env template.
# Copy to .plan-bakeoff.env and fill only the keys you want to enable.

# Codex CLI via Responses-compatible router.
CODEX_BASE_URL=https://api-router.evad.mioffice.cn/v1
CODEX_API_KEY=

# MiniMax: Codex Responses route and Claude Code Anthropic-compatible route.
MM_BASE_URL=https://api.minimaxi.com/v1
MM_API_KEY=

# MiMo 1000 / MiMo v2.5 Pro UltraSpeed.
# MIMO_BASE_URL may include /v1; the runner strips it for Claude Code.
MIMO_BASE_URL=
MIMO_API_KEY=

# Kimi coding route for Claude Code.
KIMI_ANTHROPIC_BASE_URL=https://api.kimi.com/coding/
KIMI_API_KEY=

# Optional MiMo token-plan route.
MIMO_ANTHROPIC_BASE_URL=https://token-plan-cn.xiaomimimo.com/anthropic
MIMO_TP_KEY=

