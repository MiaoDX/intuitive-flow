{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noEmit": true,
    "types": ["bun", "node"],
    "skipLibCheck": true
  },
  "include": ["scripts/**/*.ts", "skills/**/*.ts"]
}
